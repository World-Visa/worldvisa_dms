{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm dlx ultracite fix"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(grep -r \"notification.*comment\\\\|comment.*notification\" src/lib src/hooks --include=*.ts --include=*.tsx)"
    ]
  }
}
